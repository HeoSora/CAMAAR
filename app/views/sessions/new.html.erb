<div class="login-page">
  <div class="login-card">
    <section class="login-form-section">
      <h1>LOGIN</h1>

      <%= form_with url: login_path, method: :post, local: true do |form| %>
        <div class="form-group">
          <%= form.label :identifier, "E-mail ou matrícula" %>
          <%= form.text_field :identifier, placeholder: "aluno@aluno.unb.br" %>
        </div>

        <div class="form-group">
          <%= form.label :password, "Senha" %>
          <%= form.password_field :password, placeholder: "Password" %>
        </div>

        <%= form.submit "Entrar", class: "login-button" %>
      <% end %>

      <% if flash[:alert].present? %>
        <p class="login-error"><%= flash[:alert] %></p>
      <% end %>
    </section>

    <section class="login-welcome-section">
      <h2>Bem vindo<br>ao<br>Camaar</h2>
    </section>
  </div>
</div>